<view class="container">
  <scroll-view class="chat-area" scroll-y="true" scroll-into-view="{{scrollIntoViewId}}">
    <view wx:for="{{chatList}}" wx:key="id" id="chat-item-{{item.id}}" class="chat-row {{item.role === 'user' ? 'user-row' : 'ai-row'}}">
      <view class="chat-item {{item.role === 'user' ? 'user-item' : 'ai-item'}}">
        <view class="chat-bubble {{item.role === 'user' ? 'user-bubble' : 'ai-bubble'}}">
          {{item.content}}
        </view>
        <text class="chat-timestamp">{{item.timestamp}}</text>
      </view>
    </view>
  </scroll-view>
  <view wx:if="{{showHistoryPanel}}" class="history-panel">
    <scroll-view class="history-list" scroll-y="true">
      <view
        wx:for="{{historyList}}"
        wx:key="id"
        class="history-item {{currentSessionId === item.id ? 'active' : ''}}"
      >
        <view class="history-main" bindtap="onSelectHistory" data-id="{{item.id}}">
          <text class="history-question">{{item.lastQuestion}}</text>
          <text class="history-time">{{item.timestamp}}</text>
        </view>
        <button class="history-del-btn" data-id="{{item.id}}" bindtap="onDeleteHistory">删除</button>
      </view>
    </scroll-view>
  </view>
  <view class="input-area">
    <button class="new-session-btn" bindtap="onNewSessionTap">+</button>
    <input
      class="question-input"
      value="{{inputValue}}"
      placeholder="请输入你的问题"
      confirm-type="send"
      bindinput="onInputChange"
    />
    <button class="input-btn send-btn" bindtap="onSendTap">发送</button>
    <button class="input-btn history-btn" bindtap="onHistoryTap">历史</button>
  </view>
</view>
