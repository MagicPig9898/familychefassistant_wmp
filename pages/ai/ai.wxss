.container {
  height: 100vh;
  position: relative;
  background-color: #f6f7fb;
}

.chat-area {
  height: 100vh;
  padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.chat-row {
  width: 100%;
  display: flex;
  margin-bottom: 20rpx;
}

.ai-row {
  justify-content: flex-start;
}

.user-row {
  justify-content: flex-end;
}

.chat-item {
  display: flex;
  flex-direction: column;
}

.ai-item {
  align-items: flex-start;
}

.user-item {
  align-items: flex-end;
}

.chat-bubble {
  max-width: 72%;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.ai-bubble {
  background-color: #ffffff;
  color: #333333;
}

.user-bubble {
  background-color: #ffd84d;
  color: #2a2a2a;
}

.chat-timestamp {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.history-panel {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  max-height: 50vh;
  z-index: 100;
  background-color: #ffffff;
  border: 1rpx solid #ebedf0;
  border-radius: 14rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.history-list {
  max-height: 360rpx;
}

.history-item {
  min-height: 90rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f2f3f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item.active {
  background-color: #fff8d6;
}

.history-main {
  flex: 1;
  min-width: 0;
  padding: 14rpx 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.history-question {
  font-size: 26rpx;
  color: #1f2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #b3bac5;
}

.history-del-btn {
  margin: 0 0 0 16rpx;
  width: 88rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #ef4444;
  background-color: #fff1f2;
}

.history-del-btn::after {
  border: none;
}

.input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1rpx solid #ebedf0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.new-session-btn {
  margin: 0;
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  padding: 0;
  font-size: 38rpx;
  font-weight: 500;
  color: #4a4a4a;
  background-color: #f0f2f5;
}

.new-session-btn::after {
  border: none;
}

.question-input {
  flex: 1;
  height: 72rpx;
  background-color: #f5f6fa;
  border-radius: 12rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-btn {
  margin: 0;
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 0;
}

.send-btn {
  background-color: #ffd84d;
  color: #2a2a2a;
}

.history-btn {
  background-color: #f0f2f5;
  color: #4a4a4a;
}
