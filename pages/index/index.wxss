/* pages/index/index.wxss */
/* 整体容器 */
.container {
  height: 100vh; /* 占满整个屏幕高度 */
  display: flex;
  flex-direction: column;
}

/* 主区域（左右布局） */
.main {
  flex: 1; /* 占满剩余空间 */
  display: flex; /* 横向排列 */
}

/* 左侧分类 */
.left {
  width: 30%; /* 占 1/3 */
  background-color: #f5f5f5;
  border-right: 1rpx solid #eee;
}

/* 分类项 */
.category-item {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

/* 当前选中的分类 */
.category-item.active {
  background-color: #ffffff;
  color: #FFD700;
  font-weight: bold;
}

.sub-category-list {
  background-color: #ffffff;
}

.sub-category-item {
  padding: 20rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  border-bottom: 1rpx solid #f0f0f0;
}

.sub-category-item.active {
  color: #FFD700;
  font-weight: bold;
}

/* 右侧菜品区域 */
.right {
  width: 70%; /* 占 2/3 */
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 单个菜品 */
.food-item {
  min-height: 18%;
  padding: 20rpx;
  border-radius: 16rpx;
  background-color: #ffffff;
  border: 1rpx solid #eee;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.food-image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.food-content {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 96rpx;
}

/* 菜名 */
.food-name {
  display: block;
  font-size: 34rpx;
  color: #222222;
}

.food-detail {
  font-size: 24rpx;
  color: #2f7cff;
}

/* AI 悬浮按钮 - 可拖拽区域铺满屏幕 */
.movable-area {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;  /* 区域本身不拦截点击 */
  z-index: 999;
}

/* 按钮本体 */
.ai-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  pointer-events: auto;  /* 按钮自身可以点击和拖拽 */
  overflow: hidden;  /* 圆形裁剪 */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  background-color: #fff;
}

/* 按钮里的图片 */
.ai-btn-img {
  width: 100%;    /* 填满按钮宽度 */
  height: 100%;   /* 填满按钮高度 */
}
