/* pages/index/index.wxss */
/* 整体容器 */
.container {
  height: 100vh; /* 占满整个屏幕高度 */
  display: flex;
  flex-direction: column;
}

/* 主区域（左右布局） */
.main {
  flex: 1; /* 占满剩余空间 */
  display: flex; /* 横向排列 */
}

/* 左侧分类 */
.left {
  width: 30%; /* 占 1/3 */
  background-color: #f5f5f5;
  border-right: 1rpx solid #eee;
}

/* 分类项 */
.category-item {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

/* 当前选中的分类 */
.category-item.active {
  background-color: #ffffff;
  color: #FFD700;
  font-weight: bold;
}

/* 右侧菜品区域 */
.right {
  width: 70%; /* 占 2/3 */
  padding: 20rpx;
  box-sizing: border-box;
}

/* 单个菜品 */
.food-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

/* 菜名 */
.food-name {
  display: block;
  font-size: 32rpx;
}

/* 价格 */
.food-price {
  color: #ff6600;
  font-size: 28rpx;
}