<!--pages/index/index.wxml--> 
<view class="container">
  <!-- 左右布局容器 -->
  <view class="main">

    <!-- 左侧分类 -->
    <view class="left">
      <view wx:if="{{loginInfo}}">
        <block wx:for="{{categories}}" wx:key="id">
          <view
            class="category-item {{expandedCategoryId === item.id ? 'active' : ''}}"
            bindtap="toggleCategory"
            data-id="{{item.id}}"
          >
            {{item.name}}
          </view>
          <view wx:if="{{expandedCategoryId === item.id}}" class="sub-category-list">
            <view
              wx:for="{{item.children}}"
              wx:key="id"
              class="sub-category-item {{currentSubCategoryId === item.id ? 'active' : ''}}"
              catchtap="selectSubCategory"
              data-id="{{item.id}}"
            >
              {{item.name}}
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 右侧菜品 -->
    <view class="right">
      <view 
        wx:if="{{loginInfo}}"
        wx:for="{{foods}}" 
        wx:key="id"
        class="food-item"
      >
        <image class="food-image" src="{{item.image}}" mode="aspectFill" />
        <view class="food-content">
          <text class="food-name">{{item.name}}</text>
          <text class="food-detail" bindtap="onFoodDetailTap" data-id="{{item.id}}">查看详情</text>
        </view>
      </view>
    </view>

  </view>

  <!-- AI 悬浮按钮（可拖拽） -->
  <movable-area class="movable-area">
    <movable-view 
      class="ai-btn" 
      direction="all" 
      x="{{aiBtnX}}" 
      y="{{aiBtnY}}"
      bindtap="onAiBtnTap"
    >
      <image class="ai-btn-img" src="/images/ai-icon.png" mode="aspectFill" />
    </movable-view>
  </movable-area>
</view>
